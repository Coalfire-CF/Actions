IS_FIRST_PARTY='false'
APPLIES_TO_REPO='true'
RISK_SUMMARY='Dependency list unavailable'
DEP_GROUP='github-actions'
PARSE_ERROR='true'
SC_ERRORS='0'
BC_ERRORS='0'
